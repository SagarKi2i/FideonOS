SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=4096
FRONTEND_URL=http://localhost:3000

# Valkey (Redis-compatible queue/cache). Used by the rate limiter and the
# Electron OTC flow. If unset, the backend falls back to a per-instance
# in-memory store (fine for dev, NOT shared across instances in staging/prod).
# Dev: run Valkey locally (e.g. `docker run -d -p 6379:6379 valkey/valkey:8`).
# Staging/prod: point at the Valkey service on the Supabase Azure VM,
# e.g. valkey://<vm-private-ip>:6379
VALKEY_URL=valkey://localhost:6379
