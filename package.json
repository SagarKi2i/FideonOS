{
  "name": "fideon-os",
  "version": "1.0.0",
  "description": "Fideon OS — AI agent platform for insurance",
  "author": "Fideon",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "electron": "electron electron/main.cjs",
    "build:frontend": "cd frontend && npm run build",
