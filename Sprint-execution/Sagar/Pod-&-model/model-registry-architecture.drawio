                <mxCell id="t_darch" value="archive" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="state_dep" target="state_arch" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="route_title" value="&lt;b&gt;Routing — picking a version for (user_id, model_id) at session start&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;align=left;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="290" width="900" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="r1" value="&lt;b&gt;1. Pinned?&lt;/b&gt;&#10;&#10;activated_models.pinned_version_id&#10;set for this broker?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="335" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="r2" value="&lt;b&gt;2. Canary bucket?&lt;/b&gt;&#10;&#10;bucket = hash(user_id+model_id) % 100&#10;&#10;Falls inside any canary&#10;percentage window?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="340" y="320" width="260" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="r3" value="&lt;b&gt;3. Active version&lt;/b&gt;&#10;&#10;The single row with&#10;rollout_state = 'active'&#10;for this model_id." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="680" y="335" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="r_result" value="&lt;b&gt;version_id resolved&lt;/b&gt;&#10;&#10;Cached on pod_sessions.&#10;Same version for every&#10;message in this session.&#10;&#10;Bucket is stable across&#10;sessions — same broker&#10;keeps the same canary." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="980" y="335" width="240" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="rr1_y" value="yes → use pinned" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;strokeColor=#82b366;fontColor=#82b366;" parent="1" source="r1" target="r_result" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rr1_n" value="no" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="r1" target="r2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rr2_y" value="yes → canary" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;strokeColor=#82b366;fontColor=#82b366;" parent="1" source="r2" target="r_result" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rr2_n" value="no" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="r2" target="r3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rr3" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" source="r3" target="r_result" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="lineage_title" value="&lt;b&gt;Lineage write&lt;/b&gt; — every decision_record carries the version that produced it" style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;align=left;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="530" width="900" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="ln_sess" value="&lt;b&gt;pod_sessions&lt;/b&gt;&#10;&#10;version_id resolved at&#10;session start and cached&#10;here for the duration." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="575" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ln_chat" value="&lt;b&gt;Chat handler&lt;/b&gt;&#10;&#10;Pulls prompt_template from&#10;model_versions.&#10;&#10;Streams to Anthropic.&#10;Builds the decision payload." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="300" y="575" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="ln_decision" value="&lt;b&gt;decision_records&lt;/b&gt;&#10;&#10;INSERT sets:&#10;• pod_session_id&#10;• model_version_id  ← NOT NULL&#10;• prompt_snapshot (denormalised&#10;  copy of prompt_template at decision time)&#10;• ai_recommendation, key_factors, …&#10;&#10;The FK that has been dead is&#10;finally populated on every new row." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="580" y="575" width="320" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="ln_backfill" value="&lt;b&gt;Backfill&lt;/b&gt;&#10;&#10;Pre-registry decisions get&#10;a synthetic version row:&#10;&#10;  model_id = 'unknown'&#10;  version  = 'pre-registry'&#10;  rollout_state = 'archived'&#10;&#10;Run once after the lineage&#10;writer ships." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="940" y="575" width="240" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="ln_audit" value="&lt;b&gt;model_version_promotions&lt;/b&gt;&#10;NEW — immutable audit log&#10;&#10;• version_id&#10;• from_state, to_state&#10;• actor_id, reason&#10;• canary_percentage_before/after&#10;• created_at&#10;&#10;Written in the same SQL&#10;transaction as any state&#10;or canary % change." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="575" width="260" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="le1" style="endArrow=block;html=1;strokeWidth=2;fontColor=#000000;" parent="1" source="ln_sess" target="ln_chat" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="le2" style="endArrow=block;html=1;strokeWidth=2;fontColor=#000000;" parent="1" source="ln_chat" target="ln_decision" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="le3" value="one-time" style="endArrow=block;html=1;strokeWidth=2;dashed=1;fontSize=10;fontStyle=2;fontColor=#000000;" parent="1" source="ln_backfill" target="ln_decision" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="api_title" value="&lt;b&gt;API surface&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;align=left;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="790" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="api_box" value="&lt;b&gt;Reads (JWT)&lt;/b&gt;&#10;GET    /api/governance/model-versions                       list (admin sees archived)&#10;GET    /api/governance/model-versions/{id}                   detail + promotion history&#10;GET    /api/governance/model-versions/by-pod/{model_id}     lifecycle timeline for one pod&#10;GET    /api/governance/model-versions/{id}/decisions        decisions produced by this version&#10;GET    /api/governance/model-versions/diff?a=…&amp;b=…           field-by-field diff&#10;&#10;&lt;b&gt;Writes (JWT + admin)&lt;/b&gt;&#10;POST   /api/admin/model-versions                              create draft&#10;PATCH  /api/admin/model-versions/{id}                         edit draft (locked once promoted)&#10;POST   /api/admin/model-versions/{id}/promote                 draft→canary, canary→active, dep→active&#10;POST   /api/admin/model-versions/{id}/deprecate               active→deprecated&#10;POST   /api/admin/model-versions/{id}/archive                 deprecated→archived&#10;PATCH  /api/admin/model-versions/{id}/canary                  adjust canary_percentage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=left;spacingLeft=14;spacingTop=10;verticalAlign=top;fontFamily=Courier New;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="820" width="900" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="ui_box" value="&lt;b&gt;Admin UI&lt;/b&gt;&#10;frontend/app/(app)/admin/registry/&#10;&#10;• /admin/registry           Pod cards (active + canary %)&#10;• /admin/registry/[pod_id]  Timeline of versions, promote / canary controls&#10;• /admin/registry/[pod_id]/[version_id]&#10;       Prompt editor (draft only), diff, decisions table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="960" y="820" width="600" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="footer2" value="See model-registry-plan.md for phasing; see pod-deployment-architecture.drawio for the runtime side." style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;align=center;verticalAlign=middle;fontColor=#666666;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="925" width="1520" height="25" as="geometry"/>
                </mxCell>
            </root>
