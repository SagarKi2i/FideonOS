                <mxCell id="t_ad" value="auto on canary→active" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="state_active" target="state_dep" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t_da_back" value="rollback (requires no current active)" style="endArrow=block;html=1;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;fontStyle=2;strokeColor=#82b366;fontColor=#82b366;" parent="1" source="state_dep" target="state_active" edge="1">
