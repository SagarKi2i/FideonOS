                <mxCell id="t_ca" value="promote (demotes current active)" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="state_canary" target="state_active" edge="1">
