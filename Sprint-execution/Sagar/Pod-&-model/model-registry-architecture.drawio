                <mxCell id="t_dc" value="promote" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="state_draft" target="state_canary" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
