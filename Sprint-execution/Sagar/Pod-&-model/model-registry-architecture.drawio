<mxfile host="65bd71144e">
    <diagram id="registry-page-current" name="1. Current State">
        <mxGraphModel dx="1600" dy="1107" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="950" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p1_title" value="&lt;b&gt;1. Current State&lt;/b&gt; — Registry exists structurally" style="text;html=1;strokeColor=none;fillColor=#fff8dc;fontSize=14;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="10" width="1520" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&#10;&#10;Green — code that is wired and correct&#10;Yellow — code that runs but is wrong&#10;Gray (dashed) — table exists, nothing&#10;             reads or writes it" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="70" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="domain_prompts" value="&lt;b&gt;A. Where prompts actually live&lt;/b&gt;&#10;&#10;&lt;b&gt;backend/services/anthropic.py&lt;/b&gt; — line 16-22&#10;&#10;DOMAIN_PROMPTS: dict[str, str] = {&#10;    &quot;insurance&quot;: &quot;You are an insurance domain expert…&quot;,&#10;    &quot;healthcare&quot;: &quot;…&quot;,&#10;    &quot;banking&quot;: &quot;…&quot;,&#10;    &quot;legal&quot;: &quot;…&quot;,&#10;    &quot;travel&quot;: &quot;…&quot;,&#10;}&#10;&#10;Changing a prompt = backend deploy.&#10;Five prompts total. No versions.&#10;No hash, no audit trail." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="70" width="380" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="chat_call" value="&lt;b&gt;Chat handler resolves prompt by domain&lt;/b&gt;&#10;&#10;backend/routers/chat.py → services/anthropic.py&#10;&#10;system = DOMAIN_PROMPTS.get(model_id, DEFAULT_PROMPT)&#10;&#10;The pod (allocation row) is never read.&#10;The version table is never read." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="440" y="70" width="400" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="static_marketplace" value="&lt;b&gt;B. Catalog also hard-coded&lt;/b&gt;&#10;&#10;frontend/lib/insuranceMocks.ts&#10;&#10;brokerModels[], mgaModels[], carrierModels[]&#10;— static arrays the marketplace renders.&#10;&#10;No DB-backed catalog yet." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="860" y="70" width="440" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="tbl_versions" value="&lt;b&gt;C. model_versions&lt;/b&gt; — defined, empty&#10;&#10;Schema (migration 20260421224737):&#10;• id (uuid)&#10;• model_id (text), version (text)&#10;• prompt_template (text)&#10;• prompt_hash (text)&#10;• rules_hash (text)&#10;• metadata (jsonb)&#10;• is_active (bool)  ← single flag, insufficient&#10;• UNIQUE (model_id, version)&#10;&#10;Row count: 0.&#10;Writer endpoints: none." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#999999;dashed=1;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="380" width="380" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="tbl_decisions" value="&lt;b&gt;D. decision_records&lt;/b&gt; — FK exists, never populated&#10;&#10;model_version_id UUID REFERENCES model_versions(id)&#10;ON DELETE SET NULL&#10;&#10;Every row written so far has model_version_id = NULL.&#10;The lineage from a decision back to the prompt that&#10;produced it is &lt;b&gt;structurally possible but operationally missing&lt;/b&gt;.&#10;&#10;Also captures:&#10;• ai_recommendation, ai_output_snapshot&#10;• key_factors, reason_summary&#10;• final_decision, final_decision_by&#10;• ai_human_agreement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="440" y="380" width="500" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="gov_endpoint" value="&lt;b&gt;E. The buggy endpoint&lt;/b&gt;&#10;&#10;backend/routers/governance.py:54-64&#10;&#10;@router.get(&quot;/model-versions&quot;)&#10;async def get_model_versions(...):&#10;    result = (&#10;      sb.table(&quot;activated_models&quot;)  ← WRONG&#10;        .select(&quot;*&quot;)&#10;        .eq(&quot;user_id&quot;, user_id)&#10;        .order(&quot;updated_at&quot;, desc=True)&#10;        .execute()&#10;    )&#10;    return result.data&#10;&#10;Phase 0 fix: change &quot;activated_models&quot;&#10;          → &quot;model_versions&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="960" y="380" width="340" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="ui_versions" value="&lt;b&gt;F. UI consumer&lt;/b&gt;&#10;&#10;frontend/app/(app)/governance/model-versions/page.tsx&#10;&#10;Calls governanceApi.modelVersions() →&#10;currently shows allocations, not versions.&#10;&#10;After Phase 0: shows an empty list&#10;until Phase 1 seeds the table." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="690" width="420" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="other_writers" value="&lt;b&gt;G. Other writers we'll wire later&lt;/b&gt;&#10;&#10;• Training jobs (training_jobs)&#10;     — could propose a new draft version&#10;     when a job finishes (out of scope)&#10;&#10;• Workflow definitions (workflows.definition)&#10;     — candidate source for rules_hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="480" y="690" width="420" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="gaps_summary" value="&lt;b&gt;What today gets wrong&lt;/b&gt;&#10;&#10;• Endpoint reads the wrong table&#10;• Five prompts live in code, not data&#10;• Marketplace is a static array&#10;• decision_records lineage FK is NULL&#10;• &quot;is_active&quot; bool can't express canary&#10;  or deprecated states" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8dc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="920" y="690" width="380" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="ec1" value="&lt;b&gt;1.&lt;/b&gt; reads dict every request" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="chat_call" target="domain_prompts" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ec2" value="&lt;b&gt;X.&lt;/b&gt; never read" style="endArrow=block;html=1;strokeWidth=2;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=2;strokeColor=#b85450;fontColor=#b85450;" parent="1" source="chat_call" target="tbl_versions" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ec3" value="&lt;b&gt;X.&lt;/b&gt; FK never populated" style="endArrow=block;html=1;strokeWidth=2;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=2;strokeColor=#b85450;fontColor=#b85450;" parent="1" source="tbl_decisions" target="tbl_versions" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ec4" value="&lt;b&gt;⚠&lt;/b&gt; wrong table" style="endArrow=block;html=1;strokeWidth=3;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;strokeColor=#FF0000;fontColor=#000000;" parent="1" source="gov_endpoint" target="tbl_decisions" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="ec5" value="" style="endArrow=block;html=1;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;fontColor=#000000;" parent="1" source="ui_versions" target="gov_endpoint" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="footer" value="See Page 2 for the target registry: lifecycle, canary routing, lineage write, admin UI." style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;align=center;verticalAlign=middle;fontColor=#666666;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="900" width="1520" height="30" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="registry-page-target" name="2. Target Registry">
