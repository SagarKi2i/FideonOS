                <mxCell id="e1" value="&lt;b&gt;1.&lt;/b&gt; trigger" style="endArrow=block;html=1;strokeWidth=3;fontSize=11;labelBackgroundColor=#ffffff;fontStyle=1;strokeColor=#FF0000;fontColor=#000000;" parent="1" source="user" target="clients" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
