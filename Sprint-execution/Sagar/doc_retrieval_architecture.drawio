                <mxCell id="step6" value="6.&#10;File in AMS&#10;(stub in v0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#999999;dashed=1;fontSize=11;align=center;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="571" width="200" height="90" as="geometry"/>
