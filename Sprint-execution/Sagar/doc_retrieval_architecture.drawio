                <mxCell id="ref_auth" value="&lt;b&gt;Auth Layer · Adapter Layer · MFA Plugin Registry · Encryption Keys&lt;/b&gt; → see Page 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=11;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
