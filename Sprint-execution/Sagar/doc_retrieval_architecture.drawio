                </mxCell>
                <mxCell id="db" value="&lt;b&gt;F. Self-hosted Supabase (Azure VM)&lt;/b&gt;&lt;br&gt;Reached only via App Gateway · SSH tunnel for migrations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#b85450;verticalAlign=top;fontStyle=1;fontSize=12;align=center;spacingTop=8;fontColor=#000000;" parent="1" vertex="1">
