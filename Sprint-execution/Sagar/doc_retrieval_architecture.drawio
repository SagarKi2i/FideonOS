                <mxCell id="ref_mlops" value="&lt;b&gt;Build &amp;amp; deploy infrastructure (ACR · SonarQube · Env Gates) &amp;amp; Event Flow&lt;/b&gt; → see Page 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=11;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
