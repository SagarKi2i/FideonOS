<mxfile host="65bd71144e">
    <diagram id="page-runtime" name="1. Runtime Flow">
        <mxGraphModel dx="1724" dy="1207" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="950" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p1_title" value="&lt;b&gt;1. Runtime Flow&lt;/b&gt; — Doc Retrieval · Web (Azure)" style="text;html=1;strokeColor=none;fillColor=#fff8dc;fontSize=14;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="10" width="1520" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="user" value="&lt;b&gt;A. User / Operator&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Pre-flight selections:&lt;/b&gt;&lt;br&gt;• Carrier&lt;br&gt;• Target AMS&lt;br&gt;• Attach-to: policy / activity / accounts / unrouted&lt;br&gt;• Doc type (policy_renewal · cancellation · endorsement · memo · invoice · certificate · deck_page · loss_run)&lt;br&gt;• Policy number + insured name&lt;br&gt;&lt;br&gt;&lt;b&gt;Then:&lt;/b&gt;&lt;br&gt;• Triggers Doc Retrieval&lt;br&gt;• Responds to MFA prompts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=12;align=left;spacingLeft=12;spacingTop=10;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="70" width="280" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="clients" value="&lt;b&gt;B. Clients (Web · Electron)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Web: Next.js (server-side) on Azure App Service&lt;br&gt;• Azure App Gateway in front" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=12;align=left;spacingLeft=12;spacingTop=10;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="360" y="70" width="500" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="carriers" value="&lt;b&gt;C. Mock Carrier Sites&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Carrier A — Email link / OTP&lt;br&gt;• Carrier B — TOTP (auto-solve)&lt;br&gt;• Carrier C — SMS OTP (HIL only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=12;align=left;spacingLeft=12;spacingTop=10;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="900" y="70" width="380" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="chain" value="&lt;b&gt;Workflow Chain Runtime&lt;/b&gt;&lt;br&gt;EXTERNAL — optional&lt;br&gt;&lt;br&gt;Dispatches to the Run Endpoint." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;dashed=1;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;spacingTop=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="70" width="240" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="backend" value="&lt;b&gt;E. Backend (FastAPI) — Azure App Service&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=8;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="336" width="1240" height="540" as="geometry"/>
                </mxCell>
                <mxCell id="runep" value="&lt;b&gt;Run Endpoint&lt;/b&gt; — POST /api/agents/doc_retrieval_v0/run&#10;Creates a row in &lt;b&gt;runs&lt;/b&gt;, enqueues job, returns &lt;b&gt;202 Accepted + run_id&lt;/b&gt; immediately." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="60" y="371" width="1200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="worker" value="&lt;b&gt;Worker / Job Runner&lt;/b&gt; — async process on &lt;b&gt;Valkey&lt;/b&gt; (co-located with self-hosted Supabase on the Azure VM)&#10;Picks runs from the queue, executes the orchestrator, updates runs.status at each step. Concurrency capped (parked Playwright sessions ≈ 200 MB each)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;verticalAlign=middle;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="60" y="446" width="1200" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="orch" value="Doc Retrieval Agent (Orchestrator) — step pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=12;fontStyle=1;align=center;spacingTop=6;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="60" y="531" width="1200" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="step1" value="1.&#10;Authenticate&#10;(login + MFA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="80" y="571" width="180" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="step2" value="2.&#10;List Documents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="270" y="571" width="180" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="step3" value="3.&#10;Filter by doc_types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="460" y="571" width="180" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="step4" value="4.&#10;Download Documents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="650" y="571" width="180" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="step5" value="5.&#10;Classify + validate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="840" y="571" width="180" height="90" as="geometry"/>
